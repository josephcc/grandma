---
import BaseLayout from '../../layouts/BaseLayout.astro';
import PageHero from '../../components/PageHero.astro';
import DonationInfo from '../../components/DonationInfo.astro';
import { getEntry, render } from 'astro:content';

const entry = await getEntry('pages', 'en/donate');
if (!entry) throw new Error('Content not found: en/donate');
const { Content } = await render(entry);
---

<BaseLayout title={entry.data.title} description={entry.data.description} lang="en" locale="en">
  <PageHero title="Donate" subtitle="愛心捐款" />
  <article class="max-w-3xl mx-auto px-4 sm:px-6 py-16 md:py-24">
    <div class="prose prose-lg prose-gray max-w-none prose-headings:text-brand-teal prose-headings:font-sans prose-a:text-brand-teal prose-p:text-gray-500 prose-h1:hidden reveal">
      <Content />
    </div>
    <div class="reveal">
      <DonationInfo locale="en" />
    </div>
  </article>
</BaseLayout>
