---
import BaseLayout from '../../layouts/BaseLayout.astro';
import PageHero from '../../components/PageHero.astro';
import { getEntry, render } from 'astro:content';

const entry = await getEntry('pages', 'en/news');
if (!entry) throw new Error('Content not found: en/news');
const { Content } = await render(entry);
---

<BaseLayout title={entry.data.title} description={entry.data.description} lang="en" locale="en">
  <PageHero title="Recent News" subtitle="最新消息" />
  <article class="max-w-3xl mx-auto px-4 sm:px-6 py-16 md:py-24 reveal">
    <div class="prose prose-lg prose-gray max-w-none prose-headings:text-brand-teal prose-headings:font-sans prose-a:text-brand-teal prose-p:text-gray-500 prose-h1:hidden prose-h2:text-xl prose-h2:mt-10 prose-h2:mb-4 prose-hr:my-10 prose-hr:border-gray-100">
      <Content />
    </div>
  </article>
</BaseLayout>
