---
import BaseLayout from '../../layouts/BaseLayout.astro';
import PageHero from '../../components/PageHero.astro';
import { getEntry, render } from 'astro:content';

const entry = await getEntry('pages', 'en/founders');
if (!entry) throw new Error('Content not found: en/founders');
const { Content } = await render(entry);
---

<BaseLayout title={entry.data.title} description={entry.data.description} lang="en" locale="en">
  <PageHero title="Founders" subtitle="創辦人" image="/images/site/hero-founders.jpg" imagePosition="top" />

  <!-- Founder portrait cards -->
  <section class="max-w-5xl mx-auto px-4 sm:px-6 -mt-16 relative z-10">
    <div class="grid md:grid-cols-2 gap-8 reveal-stagger">
      <a href="#lin-chun-yen" class="reveal bg-white rounded-2xl shadow-[0_4px_24px_rgba(0,0,0,0.08)] p-8 text-center hover:shadow-[0_8px_40px_rgba(0,0,0,0.12)] transition-all duration-300 hover:-translate-y-1 block cursor-pointer no-underline">
        <img
          src="/images/founders/lin-chun-yen.png"
          alt="Dr. Chun-Yen Lin"
          class="w-36 h-36 object-cover rounded-full mx-auto mb-5 shadow-md ring-4 ring-brand-teal/10"
        />
        <h2 class="text-xl font-bold text-gray-900 font-sans">Dr. Chun-Yen Lin</h2>
        <p class="text-brand-teal font-medium text-sm mt-1 font-sans">Founder & Honorary Chairman</p>
        <p class="text-gray-400 text-xs mt-1 font-sans">林俊彥醫師</p>
      </a>
      <a href="#lin-po-ting" class="reveal bg-white rounded-2xl shadow-[0_4px_24px_rgba(0,0,0,0.08)] p-8 text-center hover:shadow-[0_8px_40px_rgba(0,0,0,0.12)] transition-all duration-300 hover:-translate-y-1 block cursor-pointer no-underline">
        <img
          src="/images/founders/lin-po-ting.png"
          alt="Dr. Po-Ting Lin"
          class="w-36 h-36 object-cover rounded-full mx-auto mb-5 shadow-md ring-4 ring-brand-teal/10"
        />
        <h2 class="text-xl font-bold text-gray-900 font-sans">Dr. Po-Ting Lin</h2>
        <p class="text-brand-teal font-medium text-sm mt-1 font-sans">Founder & Chairman</p>
        <p class="text-gray-400 text-xs mt-1 font-sans">林伯庭醫師</p>
      </a>
    </div>
  </section>

  <!-- Biographical content -->
  <article class="max-w-3xl mx-auto px-4 sm:px-6 py-16 md:py-24 reveal">
    <div class="prose prose-lg prose-gray max-w-none prose-headings:text-brand-teal prose-headings:font-sans prose-a:text-brand-teal prose-p:text-gray-500 prose-li:text-gray-500 prose-h1:hidden prose-h2:text-2xl prose-h2:mt-12 prose-h2:pt-8 prose-h2:border-t prose-h2:border-gray-100 [&_div[id]]:scroll-mt-24">
      <Content />
    </div>
  </article>
</BaseLayout>
