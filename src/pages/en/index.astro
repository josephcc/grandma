---
import BaseLayout from "../../layouts/BaseLayout.astro";
import MissionCards from "../../components/MissionCards.astro";
import { getEntry } from "astro:content";
import siteConfig from "../../../content/site.json";

const config = siteConfig.en;
const hp = config.homepage;

const missionEntry = await getEntry("pages", "en/mission");
const storyEntry = await getEntry("pages", "en/story");
---

<BaseLayout title={config.nav.home} description={hp.description} lang="en" locale="en">
  <!-- Hero -->
  <section class="relative bg-brand-teal overflow-hidden">
    <img
      src="/images/site/hero-background.jpg"
      alt=""
      class="absolute inset-0 w-full h-full object-cover opacity-35"
    />
    <div
      class="absolute inset-0 bg-gradient-to-br from-brand-teal-dark/90 via-brand-teal/80 to-brand-green/70"
    >
    </div>

    <div
      class="relative max-w-5xl mx-auto px-4 sm:px-6 py-16 md:py-24 text-center"
    >
      <p
        class="text-brand-gold text-sm font-medium uppercase tracking-[0.2em] mb-6 font-sans"
      >
        {hp.tagline}
      </p>
      <h1
        class="text-3xl sm:text-4xl md:text-5xl font-bold text-white leading-[1.15] mb-4"
      >
        {hp.heroTitle[0]}<br />{hp.heroTitle[1]}
      </h1>
      <p
        class="text-base sm:text-lg text-white/60 mb-8 max-w-xl mx-auto font-sans font-light"
      >
        {hp.heroSubtitle}
      </p>
    </div>
  </section>

  <!-- Mission section — rendered from content/en/mission.md -->
  <section id="mission" class="py-24 md:py-32 scroll-mt-20">
    <div class="max-w-6xl mx-auto px-4 sm:px-6">
      <div class="text-center mb-12 reveal">
        <p
          class="text-brand-gold text-sm font-medium uppercase tracking-[0.15em] mb-3 font-sans"
        >
          {hp.missionLabel}
        </p>
        <h2 class="text-3xl md:text-4xl font-bold text-brand-teal">
          {missionEntry!.data.title}
        </h2>
      </div>
      <div class="reveal">
        <MissionCards body={missionEntry!.body!} />
      </div>
    </div>
  </section>

  <!-- Story section — teaser from content/en/story.md frontmatter -->
  <section class="py-24 md:py-32 bg-white">
    <div class="max-w-6xl mx-auto px-4 sm:px-6">
      <div class="grid md:grid-cols-5 gap-12 md:gap-16 items-center">
        <div class="md:col-span-2 reveal">
          <div class="relative">
            <div
              class="absolute -inset-4 bg-brand-teal/5 rounded-3xl -rotate-3"
            >
            </div>
            <img
              src="/images/founders/lin-huang-yueh-ying.png"
              alt="Ms. Huang Yueh-Ying Lin"
              class="relative rounded-2xl shadow-xl w-full object-cover"
            />
          </div>
        </div>
        <div class="md:col-span-3 reveal">
          <p
            class="text-brand-gold text-sm font-medium uppercase tracking-[0.15em] mb-3 font-sans"
          >
            {hp.storyLabel}
          </p>
          <h2 class="text-3xl md:text-4xl font-bold text-brand-teal mb-6">
            {storyEntry!.data.title}
          </h2>
          <p class="text-gray-500 text-lg leading-relaxed mb-8">
            {storyEntry!.data.description}
          </p>
          <a
            href="/en/story"
            class="inline-flex items-center gap-2 text-brand-teal font-semibold font-sans group"
          >
            {hp.storyLink}
            <svg
              class="w-4 h-4 transition-transform duration-200 group-hover:translate-x-1"
              fill="none"
              viewBox="0 0 24 24"
              stroke="currentColor"
              stroke-width="2"
              ><path
                stroke-linecap="round"
                stroke-linejoin="round"
                d="M13.5 4.5L21 12m0 0l-7.5 7.5M21 12H3"></path></svg
            >
          </a>
        </div>
      </div>
    </div>
  </section>

  <!-- CTA -->
  <section class="py-24 md:py-32 bg-brand-teal relative overflow-hidden">
    <div
      class="absolute top-0 right-0 w-80 h-80 rounded-full bg-white/[0.03] -translate-y-1/2 translate-x-1/3"
    >
    </div>
    <div
      class="absolute bottom-0 left-0 w-64 h-64 rounded-full bg-white/[0.03] translate-y-1/2 -translate-x-1/3"
    >
    </div>
    <div class="relative max-w-3xl mx-auto px-4 sm:px-6 text-center reveal">
      <h2 class="text-3xl md:text-4xl font-bold text-white mb-5">
        {hp.ctaHeading}
      </h2>
      <p class="text-white/60 text-lg mb-10 font-sans">
        {hp.ctaBody}
      </p>
      <a
        href="/en/donate"
        class="inline-flex items-center gap-2 px-10 py-4 bg-brand-gold text-white rounded-full font-semibold font-sans text-lg hover:bg-brand-gold/90 transition-all duration-200 shadow-lg hover:shadow-xl hover:-translate-y-0.5"
      >
        {hp.ctaButton}
        <svg
          class="w-5 h-5"
          fill="none"
          viewBox="0 0 24 24"
          stroke="currentColor"
          stroke-width="2"
          ><path
            stroke-linecap="round"
            stroke-linejoin="round"
            d="M13.5 4.5L21 12m0 0l-7.5 7.5M21 12H3"></path></svg
        >
      </a>
    </div>
  </section>
</BaseLayout>
